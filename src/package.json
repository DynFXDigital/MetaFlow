{
  "name": "metaflow",
  "displayName": "MetaFlow",
  "description": "AI metadata overlay management for GitHub Copilot — deterministic overlay resolution, materialization with provenance, and profile/layer management",
  "version": "0.1.0",
  "publisher": "kiates",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiates/MetaFlow.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "ai",
    "metadata",
    "overlay",
    "metaflow"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/.metaflow/config.jsonc"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "metaflow.refresh",
        "title": "MetaFlow: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "metaflow.preview",
        "title": "MetaFlow: Preview Overlay",
        "icon": "$(eye)"
      },
      {
        "command": "metaflow.apply",
        "title": "MetaFlow: Apply Overlay",
        "icon": "$(check)"
      },
      {
        "command": "metaflow.clean",
        "title": "MetaFlow: Clean Managed Files",
        "icon": "$(trash)"
      },
      {
        "command": "metaflow.status",
        "title": "MetaFlow: Status",
        "icon": "$(info)"
      },
      {
        "command": "metaflow.switchProfile",
        "title": "MetaFlow: Switch Profile",
        "icon": "$(symbol-enum)"
      },
      {
        "command": "metaflow.toggleLayer",
        "title": "MetaFlow: Toggle Layer",
        "icon": "$(check)"
      },
      {
        "command": "metaflow.toggleRepoSource",
        "title": "MetaFlow: Toggle Repo Source",
        "icon": "$(repo)"
      },
      {
        "command": "metaflow.addRepoSource",
        "title": "MetaFlow: Add Repo Source",
        "icon": "$(add)"
      },
      {
        "command": "metaflow.removeRepoSource",
        "title": "MetaFlow: Remove Repo Source",
        "icon": "$(trash)"
      },
      {
        "command": "metaflow.openConfig",
        "title": "MetaFlow: Open Config File",
        "icon": "$(settings-gear)"
      },
      {
        "command": "metaflow.initConfig",
        "title": "MetaFlow: Initialize Configuration",
        "icon": "$(new-file)"
      },
      {
        "command": "metaflow.promote",
        "title": "MetaFlow: Promote Changes",
        "icon": "$(git-pull-request)"
      }
    ],
    "views": {
      "metaflow-container": [
        {
          "id": "metaflow-config",
          "name": "AI Metadata",
          "icon": "$(repo)"
        },
        {
          "id": "metaflow-profiles",
          "name": "Profiles",
          "icon": "$(symbol-enum)"
        },
        {
          "id": "metaflow-layers",
          "name": "Layers",
          "icon": "$(layers)"
        },
        {
          "id": "metaflow-files",
          "name": "Effective Files",
          "icon": "$(files)"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "metaflow-container",
          "title": "MetaFlow",
          "icon": "$(layers)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "metaflow-config",
        "contents": "No MetaFlow configuration found.\n[Initialize Configuration](command:metaflow.initConfig)\n[Learn More](https://github.com/kiates/MetaFlow)",
        "when": "workspaceFolderCount > 0"
      },
      {
        "view": "metaflow-config",
        "contents": "Open a folder or workspace to get started with MetaFlow.\n[Open Folder](command:vscode.openFolder)",
        "when": "workspaceFolderCount == 0"
      },
      {
        "view": "metaflow-profiles",
        "contents": "No MetaFlow configuration found.",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "menus": {
      "viewContainer/title": [
        {
          "command": "metaflow.openConfig",
          "when": "viewContainer == workbench.view.extension.metaflow-container",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "metaflow.openConfig",
          "when": "view == metaflow-config",
          "group": "navigation@1"
        },
        {
          "command": "metaflow.refresh",
          "when": "view == metaflow-config || view == metaflow-profiles || view == metaflow-layers || view == metaflow-files",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "metaflow.switchProfile",
          "when": "view == metaflow-profiles && viewItem == profile",
          "group": "inline"
        },
        {
          "command": "metaflow.toggleLayer",
          "when": "view == metaflow-layers && viewItem == layer",
          "group": "inline"
        },
        {
          "command": "metaflow.toggleRepoSource",
          "when": "view == metaflow-config && viewItem == configRepoSource",
          "group": "inline"
        },
        {
          "command": "metaflow.removeRepoSource",
          "when": "view == metaflow-config && viewItem == configRepoSource",
          "group": "inline@2"
        },
        {
          "command": "metaflow.addRepoSource",
          "when": "view == metaflow-config && viewItem == configRepoSection",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "MetaFlow",
      "properties": {
        "metaflow.enabled": {
          "type": "boolean",
          "default": true,
          "order": 1,
          "description": "Enable MetaFlow extension features"
        },
        "metaflow.autoApply": {
          "type": "boolean",
          "default": true,
          "order": 2,
          "description": "Automatically apply overlay when configuration changes"
        },
        "metaflow.logLevel": {
          "type": "string",
          "default": "info",
          "order": 6,
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "description": "Output channel log verbosity"
        },
        "metaflow.hooksEnabled": {
          "type": "boolean",
          "default": true,
          "order": 3,
          "description": "Enable hook path injection into VS Code settings"
        },
        "metaflow.injection.defaultMode": {
          "type": "string",
          "default": "settings",
          "order": 4,
          "title": "Default Injection Mode",
          "enum": [
            "settings",
            "materialize"
          ],
          "description": "Default injection mode for all artifact types"
        },
        "metaflow.injection.defaultModes": {
          "type": "object",
          "order": 5,
          "title": "Injection Modes",
          "default": {
            "instructions": "inherit",
            "prompts": "inherit",
            "skills": "inherit",
            "agents": "inherit",
            "hooks": "inherit"
          },
          "description": "Injection mode overrides by artifact type (Item = artifact type, Value = mode)",
          "additionalProperties": false,
          "properties": {
            "instructions": {
              "type": "string",
              "enum": [
                "inherit",
                "settings",
                "materialize"
              ],
              "default": "inherit",
              "description": "Injection mode override for instructions artifacts"
            },
            "prompts": {
              "type": "string",
              "enum": [
                "inherit",
                "settings",
                "materialize"
              ],
              "default": "inherit",
              "description": "Injection mode override for prompts artifacts"
            },
            "skills": {
              "type": "string",
              "enum": [
                "inherit",
                "settings",
                "materialize"
              ],
              "default": "inherit",
              "description": "Injection mode override for skills artifacts"
            },
            "agents": {
              "type": "string",
              "enum": [
                "inherit",
                "settings",
                "materialize"
              ],
              "default": "inherit",
              "description": "Injection mode override for agents artifacts"
            },
            "hooks": {
              "type": "string",
              "enum": [
                "inherit",
                "settings",
                "materialize"
              ],
              "default": "inherit",
              "description": "Injection mode override for hooks artifacts"
            }
          }
        }
      }
    },
    "keybindings": [
      {
        "command": "metaflow.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "metaflow.active"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "precompile": "npm -C ../packages/engine run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "npm run precompile && node esbuild.js --production",
    "bundle:dev": "npm run precompile && node esbuild.js",
    "watch:esbuild": "npm run precompile && node esbuild.js --watch",
    "pretest": "npm run compile && npm run bundle:dev && npm run lint",
    "lint": "eslint src --ext ts --max-warnings=-1",
    "lint:monitor": "eslint src --ext ts --max-warnings=-1 --format json --output-file .eslint-report.json",
    "lint:summary": "node ./scripts/lint-summary.js",
    "lint:monitor:summary": "npm run lint:monitor && npm run lint:summary",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npm run compile && node ./out/test/runTest.js --unit",
    "test:coverage": "c8 --reporter=text --reporter=lcov node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@metaflow/engine": "file:../packages/engine",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "c8": "^10.1.2",
    "esbuild": "^0.27.3",
    "eslint": "^8.54.0",
    "glob": "^10.3.10",
    "minimatch": "^9.0.3",
    "mocha": "^10.2.0",
    "typescript": "^5.3.2"
  }
}
