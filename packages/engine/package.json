{
  "name": "@metaflow/engine",
  "description": "Engine for layered AI metadata overlays for Copilot instructions, prompts, skills, and agents.",
  "version": "0.1.0-preview.0",
  "license": "MIT",
  "private": true,
  "main": "out/src/index.js",
  "types": "out/src/index.d.ts",
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "clean": "rimraf out",
    "pretest": "npm run build",
    "test": "mocha \"out/test/**/*.test.js\" --timeout 10000",
    "test:coverage": "c8 --reporter=text --reporter=lcov --include=out/src/** mocha \"out/test/**/*.test.js\" --timeout 10000"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  }
}
