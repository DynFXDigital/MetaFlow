{
  "name": "@metaflow/cli",
  "description": "CLI for deterministic AI metadata overlays for Copilot instructions, prompts, skills, and agents.",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "bin": {
    "metaflow": "out/src/cli.js"
  },
  "main": "out/src/cli.js",
  "types": "out/src/cli.d.ts",
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "clean": "rimraf out",
    "pretest": "npm run build",
    "test": "mocha 'out/test/**/*.test.js' --timeout 10000",
    "test:coverage": "c8 --reporter=text --reporter=lcov --include='out/src/**' mocha 'out/test/**/*.test.js' --timeout 10000"
  },
  "dependencies": {
    "@metaflow/engine": "file:../engine",
    "commander": "^11.1.0",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "c8": "^10.1.3",
    "mocha": "^10.2.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.3.2"
  }
}
