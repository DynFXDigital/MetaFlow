{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MetaFlow: Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/src",
        "--disable-extensions",
        "--user-data-dir=${workspaceFolder}/.vscode-dev-host/user-data",
        "--extensions-dir=${workspaceFolder}/.vscode-dev-host/extensions"
      ],
      "outFiles": ["${workspaceFolder}/src/dist/**/*.js"],
      "preLaunchTask": "MetaFlow: Build Extension"
    },
    {
      "name": "MetaFlow: Run Extension (Watch)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/src",
        "--disable-extensions",
        "--user-data-dir=${workspaceFolder}/.vscode-dev-host/user-data",
        "--extensions-dir=${workspaceFolder}/.vscode-dev-host/extensions"
      ],
      "outFiles": ["${workspaceFolder}/src/dist/**/*.js"],
      "preLaunchTask": "MetaFlow: Watch Extension"
    }
  ]
}
