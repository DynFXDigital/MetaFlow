{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "MetaFlow: Install Dependencies",
            "type": "npm",
            "script": "install",
            "path": ".",
            "problemMatcher": []
        },
        {
            "label": "MetaFlow: Build Workspace",
            "type": "npm",
            "script": "build",
            "path": ".",
            "problemMatcher": []
        },
        {
            "label": "MetaFlow: Watch Extension",
            "type": "npm",
            "script": "watch:esbuild",
            "path": "src",
            "problemMatcher": {
                "pattern": {
                    "regexp": "^✘ \\[ERROR\\] (.+)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^\\[watch\\] build started$",
                    "endsPattern": "^\\[watch\\] build finished$"
                }
            },
            "isBackground": true,
            "presentation": {
                "reveal": "never"
            },
            "group": "build"
        },
        {
            "label": "MetaFlow: Build Extension",
            "type": "npm",
            "script": "bundle:dev",
            "path": "src",
            "problemMatcher": "$tsc",
            "group": "build"
        },
        {
            "label": "MetaFlow: Lint Extension",
            "type": "npm",
            "script": "lint",
            "path": "src",
            "problemMatcher": []
        },
        {
            "label": "MetaFlow: Test Extension Unit",
            "dependsOrder": "sequence",
            "dependsOn": [
                "MetaFlow: Compile Extension (TS)",
                "MetaFlow: Test Extension Unit (Raw)"
            ],
            "problemMatcher": []
        },
        {
            "label": "MetaFlow: Compile Extension (TS)",
            "type": "npm",
            "script": "compile",
            "path": "src",
            "problemMatcher": "$tsc",
            "group": "build"
        },
        {
            "label": "MetaFlow: Test Extension Unit (Raw)",
            "type": "npm",
            "script": "test:unit",
            "path": "src",
            "problemMatcher": []
        },
        {
            "label": "MetaFlow: Test Extension Integration",
            "type": "npm",
            "script": "test",
            "path": "src",
            "problemMatcher": []
        },
        {
            "label": "MetaFlow: Package Extension VSIX",
            "type": "npm",
            "script": "package",
            "path": "src",
            "problemMatcher": []
        },
        {
            "label": "MetaFlow: Build + Package VSIX",
            "dependsOrder": "sequence",
            "dependsOn": [
                "MetaFlow: Build Extension",
                "MetaFlow: Package Extension VSIX"
            ],
            "problemMatcher": []
        },
        {
            "label": "MetaFlow: Install Latest VSIX",
            "type": "shell",
            "command": "& { $vsix = Get-ChildItem -Path \"${workspaceFolder}/src\" -Filter *.vsix | Sort-Object LastWriteTime -Descending | Select-Object -First 1; if (-not $vsix) { throw 'No VSIX found under src/. Run MetaFlow: Package Extension VSIX first.' }; & \"${workspaceFolder}/src/scripts/install-vsix.ps1\" -VsixPath $vsix.FullName -Cli code-insiders -ProfileName \"${config:metaflow.installProfile}\" }",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "MetaFlow: Build, Package & Install VSIX",
            "dependsOrder": "sequence",
            "dependsOn": [
                "MetaFlow: Build + Package VSIX",
                "MetaFlow: Install Latest VSIX"
            ],
            "problemMatcher": []
        }
    ]
}